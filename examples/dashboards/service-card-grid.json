{
  "title": "Service card grid",
  "panels": [
    {
      "title": "Service health",
      "type": "asimzulfiqar-devicecard-panel",
      "options": {
        "presentationMode": "fleet",
        "idField": "service",
        "titleField": "service",
        "subtitleField": "team",
        "descriptionField": "region",
        "statusField": "health",
        "metrics": [
          { "field": "latency_ms", "label": "Latency", "unit": "ms", "decimals": 0, "thresholds": [{ "operator": "gte", "value": "500", "color": "red" }] },
          { "field": "error_rate", "label": "Errors", "unit": "percentunit", "decimals": 2, "thresholds": [{ "operator": "gte", "value": "0.02", "color": "yellow" }] }
        ],
        "customFields": [
          { "name": "summary", "label": "Summary", "expression": "concat(team, \" - \", region)" }
        ],
        "statusRules": [
          { "operator": "equals", "value": "healthy", "label": "Healthy", "color": "green" },
          { "operator": "equals", "value": "degraded", "label": "Degraded", "color": "yellow" }
        ],
        "mode": "grid",
        "layout": "compact",
        "density": "compact",
        "metricStyle": "list",
        "logoPlacement": "header-right",
        "statusPlacement": "footer",
        "cardTheme": "minimal",
        "accentStyle": "left",
        "maxColumns": 4,
        "maxEntities": 500,
        "showLogo": true,
        "staticIcon": "server"
      }
    }
  ],
  "schemaVersion": 39
}
